{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Planix",
  "mainBinaryName": "planix",
  "version": "1.1.4",
  "identifier": "com.planix.app",
  "build": {
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File ../../scripts/dev-desktop.ps1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File ../../scripts/build-web.ps1",
    "frontendDist": "resources"
  },
  "app": {
    "windows": [
      {
        "title": "Planix",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Planix",
    "icon": ["icons/icon.ico"],
    "resources": {
      "resources/index.html": "resources/index.html",
      "resources/assets": "resources/assets",
      "resources/binaries/planix-api.exe": "resources/binaries/planix-api.exe"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
