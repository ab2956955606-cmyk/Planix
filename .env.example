AI_PROVIDER=mock
AI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
OPENAI_API_KEY=
AI_API_BASE=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
USE_REAL_LLM=0
DATABASE_URL=sqlite:///./data/mynotes.db
PLANIX_USE_COGNITIVE_PLANNING=false
PLANIX_COGNITIVE_MODE=true
# Cognitive Planning first-call output budgets. Each setting is clamped to its fixed task cap.
# A truncated JSON response retries the same Provider once, up to the cap, before fallback.
# Retry caps: goal/reality/learning=10800, evidence/critique=13200, strategy=14400, execution=24000.
PLANIX_GOAL_MODEL_MAX_TOKENS=5400
PLANIX_REALITY_MAX_TOKENS=5400
PLANIX_EVIDENCE_MAX_TOKENS=6600
PLANIX_STRATEGY_MAX_TOKENS=7200
PLANIX_EXECUTION_MAX_TOKENS=12000
PLANIX_CRITIQUE_MAX_TOKENS=6600
PLANIX_LEARNING_MAX_TOKENS=5400
